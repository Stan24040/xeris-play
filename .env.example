# SOLPRIZE Lottery — Environment Variables
# Copy to .env and fill in your values

# Treasury wallet private key (base58-encoded Ed25519 secret key, 64 bytes)
# Required for payouts. Without this, claim/payout will be disabled.
TREASURY_PRIVATE_KEY=

# Treasury public address (auto-derived from private key, but can override)
TREASURY_ADDRESS=6G4GroMrVsGjd3xhywxfzXDg7vPn1V2Mky4B3qsXVGHo

# Xeris node endpoints
XERIS_RPC=http://138.197.116.81:50008
XERIS_NET=http://138.197.116.81:56001
XERIS_NODE_IP=138.197.116.81

# Server port
PORT=3000
